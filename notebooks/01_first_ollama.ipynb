   "source": [
    "# First Ollama Chat\n",
    "\n",
    "Basic chat with a local model via the Ollama Python client."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import ollama\n",
    "\n",
    "response = ollama.chat(\n",
    "    model=\"llama3.2:1b\",\n",
    "    messages=[\n",
    "        {\"role\": \"user\", \"content\": \"Apa perbedaan RAG dan fine-tuning?\"}\n",
    "    ],\n",
    ")\n",
    "\n",
    "print(response[\"message\"][\"content\"])"
   ]
  }
